          "path": [
            "conversations",
            "{{conversationId}}"
          ]
        },
        "description": "Negative test: employee should not be able to manually set a conversation to `escalated`.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"escalated\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('manual escalation is forbidden', function () {",
              "  pm.response.to.have.status(403);",
              "});"
            ]
          }
        }
      ]
    },
