    {
      "name": "Post Attachment Policy Message",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{bearerToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/conversations/{{attachmentConversationId}}/messages",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "conversations",
            "{{attachmentConversationId}}",
            "messages"
          ]
        },
        "description": "Smoke-test attachment-assisted routing using inline text to avoid local file-path dependence inside Postman.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"Tolong cek lampiran ini\",\n  \"attachments\": [\n    {\n      \"file_name\": \"carry-over-policy.txt\",\n      \"inline_text\": \"Aturan carry over cuti maksimal 5 hari sampai akhir kuartal pertama.\"\n    }\n  ],\n  \"metadata\": {\n    \"channel\": \"postman\"\n  }\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('attachment message succeeded', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('route is company or mixed', function () {",
              "  pm.expect(['company', 'mixed']).to.include(body.orchestration.route);",
              "});",
              "pm.test('file-agent was used', function () {",
              "  pm.expect(body.orchestration.used_agents).to.include('file-agent');",
              "});"
            ]
          }
        }
      ]
    },
