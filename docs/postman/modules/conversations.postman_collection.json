              "  pm.collectionVariables.set('payslipConversationId', body.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Post Payslip PDF Request",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{bearerToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/conversations/{{payslipConversationId}}/messages",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "conversations",
            "{{payslipConversationId}}",
            "messages"
          ]
        },
        "description": "Trigger payroll document automation. Expected result: one completed `document_generation` action with a generated payslip PDF in `triggered_actions[0].execution_result.document`.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"Bisakah kamu tolong generate pdf, payslip saya?\",\n  \"attachments\": [],\n  \"metadata\": {\n    \"channel\": \"postman\"\n  }\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('payslip request succeeded', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('intent is payroll_document_request', function () {",
              "  pm.expect(body.orchestration.intent.primary_intent).to.eql('payroll_document_request');",
              "});",
              "pm.test('one triggered action exists', function () {",
              "  pm.expect(body.triggered_actions.length).to.eql(1);",
              "});",
              "pm.test('generated document is a pdf', function () {",
              "  pm.expect(body.triggered_actions[0].execution_result.document.mime_type).to.eql('application/pdf');",
              "});"
            ]
          }
        }
      ]
    },
