            "{{conversationId}}"
          ]
        },
        "description": "Employee is allowed to patch conversation title and metadata.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Phase 4 smoke test conversation (renamed)\",\n  \"metadata\": {\n    \"source\": \"postman\",\n    \"patched\": true\n  }\n}"
        }
      },
      "event": [
        {
          "listen": "test",
