  "item": [
    {
      "name": "Login Employee Helper",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        },
        "description": "Login as the seeded employee user and store the returned JWT in `bearerToken` for the requests below.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{employeeEmail}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('login succeeded', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "if (body.access_token) {",
              "  pm.collectionVariables.set('bearerToken', body.access_token);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Conversation",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{bearerToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/conversations",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "conversations"
          ]
        },
        "description": "Create a fresh conversation for the main smoke-test path and store the returned id in `conversationId`.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Phase 4 smoke test conversation\",\n  \"metadata\": {\n    \"source\": \"postman\",\n    \"test_case\": \"phase4_smoke\"\n  }\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('conversation created', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const body = pm.response.json();",
              "if (body.id) {",
              "  pm.collectionVariables.set('conversationId', body.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Post Mixed Message",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{bearerToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/conversations/{{conversationId}}/messages",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "conversations",
            "{{conversationId}}",
            "messages"
          ]
        },
        "description": "Smoke-test the main Phase 3 routing path through the public Phase 4 API. Expected route: `mixed`.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"Berapa sisa cuti saya tahun ini dan apa aturan carry over?\",\n  \"attachments\": [],\n  \"metadata\": {\n    \"channel\": \"postman\"\n  }\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('mixed message succeeded', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('route is mixed', function () {",
              "  pm.expect(body.orchestration.route).to.eql('mixed');",
              "});",
              "pm.test('conversation stays active', function () {",
              "  pm.expect(body.conversation.status).to.eql('active');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Conversation Detail",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{bearerToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/conversations/{{conversationId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "conversations",
            "{{conversationId}}"
          ]
        },
        "description": "Read back the current conversation and message history after posting a mixed HR/company question."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('conversation detail returned', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('messages exist', function () {",
              "  pm.expect(body.messages.length).to.be.greaterThan(0);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Conversation Actions",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{bearerToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/conversations/{{conversationId}}/actions",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "conversations",
            "{{conversationId}}",
            "actions"
          ]
        },
        "description": "List actions linked to the conversation. For a fresh smoke-test conversation this may legitimately return `total = 0` unless action automation has created a linked record."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('conversation actions returned', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Payslip Test Conversation",
      "request": {
