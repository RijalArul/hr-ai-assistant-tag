        },
        "description": "Create a fresh conversation for the self-service payslip generation flow and store the returned id in `payslipConversationId`.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Payslip generation conversation\",\n  \"metadata\": {\n    \"source\": \"postman\",\n    \"test_case\": \"payslip_generation\"\n  }\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('payslip conversation created', function () {",
