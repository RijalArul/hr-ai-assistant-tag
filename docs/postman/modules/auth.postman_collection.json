    {
      "name": "Login Employee",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        },
        "description": "Login using employee email and store the returned JWT bearer token in `bearerToken`.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{employeeEmail}}\"\n}"
        }
      },
      "response": [
        {
          "name": "200 OK - Login Employee Success",
          "originalRequest": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{employeeEmail}}\"\n}"
            }
          },
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\n  \"access_token\": \"<jwt-access-token>\",\n  \"token_type\": \"bearer\",\n  \"session\": {\n    \"employee_id\": \"20000000-0000-0000-0000-000000000004\",\n    \"company_id\": \"00000000-0000-0000-0000-000000000001\",\n    \"email\": \"fakhrul.rijal@majubersama.id\",\n    \"role\": \"employee\"\n  }\n}"
        },
        {
          "name": "401 Unauthorized - Invalid Email",
          "originalRequest": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{invalidEmployeeEmail}}\"\n}"
            }
          },
          "status": "Unauthorized",
          "code": 401,
          "_postman_previewlanguage": "json",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\n  \"detail\": \"Invalid email.\"\n}"
        }
      ],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "  const body = pm.response.json();",
              "  if (body.access_token) {",
              "    pm.collectionVariables.set('bearerToken', body.access_token);",
              "  }",
              "}"
            ]
          }
        }
      ]
