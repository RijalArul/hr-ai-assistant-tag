# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ─── Redis ───────────────────────────────────────────────────────────────────
# Railway internal: redis://default:<password>@redis.railway.internal:6379
# Local dev: redis://localhost:6379
REDIS_URL=redis://default:<password>@redis.railway.internal:6379
REDIS_HOST=redis.railway.internal
REDIS_PORT=6379
REDIS_USER=default
REDIS_PASSWORD=your-redis-password

# ─── MiniMax LLM ─────────────────────────────────────────────────────────────
MINIMAX_API_KEY=sk-cp-1_...
MINIMAX_API_BASE=https://api.minimaxi.chat/v1

# ─── Discord ─────────────────────────────────────────────────────────────────
DISCORD_APPLICATION_ID=your-application-id
DISCORD_PUBLIC_KEY=your-public-key
DISCORD_BOT_TOKEN=your-bot-token

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-random-32-char-hex-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── Gemini (file extraction) ───────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.5-flash

# ─── HuggingFace (multilingual-e5-large embeddings) ─────────────────────────
HUGGINGFACE_API_KEY=hf_...
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000
